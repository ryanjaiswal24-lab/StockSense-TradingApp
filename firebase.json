{
  "hosting": {
    "public": "predictor/frontend",
    "ignore": [
      "firebase.json",
      "database.rules.json",
      "*.py",
      "*.cpp",
      "*.exe",
      "*.md",
      "serviceAccountKey.json",
      "node_modules/**",
      "__pycache__/**",
      "*.pyc",
      "tempCodeRunnerFile.*",
      "requirements.txt",
      "deploy.md",
      "README.md",
      "Predictor here.md"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
