{
  "hosting": {
    "public": "predictor",
    "ignore": [
      "firebase.json",
      "database.rules.json",
      "*.py",
      "*.cpp",
      "*.md",
      "serviceAccountKey.json",
      "node_modules/**"
    ],
    "rewrites": [
      { "source": "**", "destination": "/index.html" }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  }
}
